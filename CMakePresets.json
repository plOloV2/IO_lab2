{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 4,
    "minor": 1
  },
  "configurePresets": [
    {
      "name": "base-ninja",
      "description": "Base configuration using Ninja generator",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}"
    },
    {
      "name": "debug_clang",
      "displayName": "Debug CLANG",
      "description": "Debug CLANG build with optimizations for current system",
      "inherits": "base-ninja",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_C_COMPILER": "clang"
      }
    },
    {
      "name": "release_clang",
      "displayName": "Release CLANG",
      "description": "Release CLANG build with optimizations for current system",
      "inherits": "base-ninja",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_C_COMPILER": "clang"
      }
    },
    {
      "name": "release_icx",
      "displayName": "Release ICX",
      "description": "Release ICX build with optimizations for current system",
      "inherits": "base-ninja",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_C_COMPILER": "icx"
      }
    },
    {
      "name": "cross_windows_gcc_static",
      "displayName": "Cross-compile Windows GCC (Static)",
      "description": "Cross-compile for Windows using GCC with static linking",
      "inherits": "base-ninja",
      "toolchainFile": "${sourceDir}/toolchains/windows-x86_64-gcc.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "USE_NATIVE_ARCH": "OFF"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "debug_clang",
      "configurePreset": "debug_clang"
    },
    {
      "name": "release_clang",
      "configurePreset": "release_clang"
    },
    {
      "name": "release_icx",
      "configurePreset": "release_icx"
    },
    {
      "name": "cross_windows_gcc_static",
      "configurePreset": "cross_windows_gcc_static"
    }
  ]
}
